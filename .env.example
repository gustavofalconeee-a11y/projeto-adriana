# Alora Acessórios - Variáveis de Ambiente (Exemplo)
# Copie este arquivo para .env e preencha os valores

# URL do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave pública (anon key) do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Chave secreta do Supabase (service role) - NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# JWT Secret para autenticação do admin
JWT_SECRET=sua_chave_secreta_jwt_aqui

# URL do site
NEXT_PUBLIC_SITE_URL=https://seu-site.vercel.app
